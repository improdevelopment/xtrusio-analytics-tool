# Database credentials
# Change these to whatever you want — use the same values
# in the "Database Setup" step of the installer.
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=xtrusio
MYSQL_USER=xtrusio_user
MYSQL_PASSWORD=your_password

# Database Server (used in installer step 3)
# This is the Docker service name — do NOT change this.
# Always use "xtrusio-db" in the Database Server field.
MYSQL_HOST=xtrusio-db

# App port (access at http://localhost:APP_PORT)
APP_PORT=8080
