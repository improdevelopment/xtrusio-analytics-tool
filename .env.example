# Xtrusio Analytics — Environment Configuration
# Copy: cp .env.example .env
#
# ⚠️  PRODUCTION (VPS) CHECKLIST:
#   1. Replace ALL passwords below with strong random values (20+ chars).
#     Generate:  openssl rand -base64 24
#   2. Set XTRUSIO_DOMAIN to your real domain.
#   3. Set XTRUSIO_FORCE_SSL=1 if behind HTTPS reverse proxy.
#   4. Never commit .env to git (already in .gitignore).

# ── MySQL Root (internal; DO NOT reuse in app credentials) ──
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD

# ── Database (these go into installer step 3, or auto-seeded in config.ini.php) ──
MYSQL_HOST=xtrusio-db   # database server name 
MYSQL_DATABASE=xtrusio
MYSQL_USER=xtrusio_user   # for login field
MYSQL_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
MYSQL_TABLE_PREFIX=xtrusio_

# ── App Port ──
# Local dev: 8080 (public). VPS: keep 8080 but compose binds to 127.0.0.1
# so only the reverse proxy (Caddy/Nginx) can reach it.
APP_PORT=8080

# ── Redis Cache ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── Production Hardening (set on VPS, leave blank for localhost) ──
# Comma-separated list of domains allowed to serve Xtrusio.
# Blocks host-header injection. Required on VPS.
# Example: XTRUSIO_TRUSTED_HOSTS=analytics.example.com
XTRUSIO_TRUSTED_HOSTS=

# Set to 1 if serving via HTTPS reverse proxy (Caddy, Nginx, Traefik).
# Without this, login cookies may break behind the proxy.
XTRUSIO_FORCE_SSL=0

# Set to 1 if running behind a reverse proxy that sets X-Forwarded-* headers.
XTRUSIO_BEHIND_PROXY=0
