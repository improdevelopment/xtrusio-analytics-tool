# Xtrusio Analytics — Environment Configuration
# Just copy this file: cp .env.example .env
# No changes needed for local setup.

# ── MySQL Root (internal, not used in installer) ──
MYSQL_ROOT_PASSWORD=xtrusio_root_2024

# ── Database Setup (use these in installer step 3) ──
MYSQL_HOST=xtrusio-db    # database server name 
MYSQL_DATABASE=xtrusio
MYSQL_USER=xtrusio_user
MYSQL_PASSWORD=xtrusio_1234
MYSQL_TABLE_PREFIX=xtrusio_

# ── App Settings ──
APP_PORT=8080
